# Google Cloud (Firestore Only)
GOOGLE_CLOUD_PROJECT=udaa-489513
GOOGLE_API_KEY=your-gemini-api-key-here

# Firestore
FIRESTORE_COLLECTION=sessions

# Gemini Models
COMPUTER_USE_MODEL=gemini-2.5-flash-preview-04-17
LIVE_MODEL=gemini-2.5-flash

# Browser / Screen
SCREEN_WIDTH=1440
SCREEN_HEIGHT=900

# Agent
MAX_AGENT_TURNS=25
AGENT_TIMEOUT_SECONDS=300
SCREENSHOT_INTERVAL=0.5

# Local Storage
LOCAL_SCREENSHOT_DIR=screenshots
